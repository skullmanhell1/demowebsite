  <script>
    const nav=document.getElementById('nav'),progress=document.getElementById('progress');window.addEventListener('scroll',()=>{nav.classList.toggle('scrolled',scrollY>20);progress.style.width=(scrollY/(document.documentElement.scrollHeight-innerHeight)*100)+'%'});const glow=document.getElementById('cursorGlow');window.addEventListener('pointermove',e=>{glow.style.left=e.clientX+'px';glow.style.top=e.clientY+'px'});
    const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');e.target.querySelectorAll?.('.counter').forEach(startCounter)}}),{threshold:.12});document.querySelectorAll('.reveal').forEach(el=>io.observe(el));const counted=new WeakSet();function startCounter(el){if(counted.has(el))return;counted.add(el);const target=+el.dataset.target;let n=0;const step=Math.max(1,Math.ceil(target/46));const t=setInterval(()=>{n+=step;if(n>=target){n=target;clearInterval(t)}el.textContent=n+(target===96?'%':'')},24)}
    const serviceSelect=document.getElementById('serviceSelect');document.querySelectorAll('.card').forEach(card=>card.addEventListener('click',()=>{serviceSelect.value=card.dataset.service;document.getElementById('booking').scrollIntoView({behavior:'smooth'})}));document.getElementById('quickBook').addEventListener('click',()=>{serviceSelect.value=document.getElementById('quickType').value});document.getElementById('bookingForm').addEventListener('submit',e=>{e.preventDefault();document.getElementById('confirm').classList.add('show')});
    document.querySelectorAll('.tilt,.media-card').forEach(el=>{el.addEventListener('pointermove',e=>{const r=el.getBoundingClientRect(),x=(e.clientX-r.left)/r.width-.5,y=(e.clientY-r.top)/r.height-.5;el.style.transform=`perspective(900px) rotateX(${y*-3}deg) rotateY(${x*3}deg) translateY(-2px)`});el.addEventListener('pointerleave',()=>el.style.transform='')});
    let reviewIndex=0;const grid=document.getElementById('reviewGrid');function moveReviews(dir){reviewIndex=Math.max(0,Math.min(1,reviewIndex+dir));grid.style.transform=`translateX(${-reviewIndex*33.333}%)`}document.getElementById('nextReview').onclick=()=>moveReviews(1);document.getElementById('prevReview').onclick=()=>moveReviews(-1);
    document.querySelectorAll('.faq-q').forEach(q=>q.addEventListener('click',()=>q.closest('.faq-item').classList.toggle('open')));
  </script>
