    const glow=document.getElementById('cursorGlow'); window.addEventListener('pointermove',e=>{glow.style.left=e.clientX+'px';glow.style.top=e.clientY+'px';});
    const io=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible'); if(e.target.querySelectorAll) e.target.querySelectorAll('.counter').forEach(startCounter);}}),{threshold:.12}); document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
    const counted=new WeakSet(); function startCounter(el){if(counted.has(el))return; counted.add(el); const target=+el.dataset.target; let n=0; const step=Math.max(1,Math.ceil(target/46)); const t=setInterval(()=>{n+=step; if(n>=target){n=target;clearInterval(t)} el.textContent=n+(target===92?'%':'');},24);} 
    document.querySelectorAll('.tilt,.image-card').forEach(el=>{el.addEventListener('pointermove',e=>{const r=el.getBoundingClientRect(); const x=(e.clientX-r.left)/r.width-.5; const y=(e.clientY-r.top)/r.height-.5; el.style.transform=`perspective(900px) rotateX(${y*-3}deg) rotateY(${x*3}deg) translateY(-2px)`;}); el.addEventListener('pointerleave',()=>el.style.transform='');});
    const appointmentType=document.getElementById('appointmentType');
    document.querySelectorAll('.card').forEach(card=>card.addEventListener('click',()=>{const title=card.querySelector('h3').textContent; const map={Dentistry:'Dental appointment',Chiropractic:'Chiropractic assessment','Med Spa':'Med spa consultation',Optometry:'Optometry exam',Physiotherapy:'Physiotherapy assessment','Integrated Care':'New patient consultation'}; appointmentType.value=map[title]||'New patient consultation'; document.getElementById('booking').scrollIntoView({behavior:'smooth'});}));
    document.getElementById('quickBook').addEventListener('click',()=>{appointmentType.value=document.getElementById('quickType').value});
    document.getElementById('bookingForm').addEventListener('submit',e=>{e.preventDefault();document.getElementById('confirm').classList.add('show')});
  </script>
