  },
  "keywords": [
    "motion-system",
    "property-based-testing",
    "dev-only"
  ],
  "license": "MIT",
  "devDependencies": {
    "fast-check": "^3.23.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "playwright": "^1.48.2"
  }
}
