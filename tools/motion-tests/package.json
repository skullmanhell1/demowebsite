{
  "name": "motion-tests",
  "version": "1.0.0",
  "private": true,
  "description": "DEV-ONLY test harness for the website-animation-ux-polish Motion_System. Never referenced by any shipped index.html.",
  "type": "commonjs",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:unit": "node --test tests/property-*.test.js tests/example-*.test.js",
